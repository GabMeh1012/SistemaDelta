<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
           https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

  <display-name>Sistema Delta UTP</display-name>

  <!-- ===== Conexión BD (parámetros XAMPP) ===== -->
  <context-param>
    <param-name>db.url</param-name>
    <param-value>jdbc:mysql://localhost:3306/sistema_delta?useSSL=false&amp;serverTimezone=America/Panama&amp;characterEncoding=UTF-8</param-value>
  </context-param>
  <context-param>
    <param-name>db.user</param-name>
    <param-value>root</param-value>
  </context-param>
  <context-param>
    <param-name>db.password</param-name>
    <param-value></param-value><!-- XAMPP root sin contraseña por defecto -->
  </context-param>

  <!-- ===== Servlets ===== -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.delta.servlet.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.delta.servlet.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MensajesServlet</servlet-name>
    <servlet-class>com.delta.servlet.MensajesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MensajesServlet</servlet-name>
    <url-pattern>/mensajes</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GruposServlet</servlet-name>
    <servlet-class>com.delta.servlet.GruposServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GruposServlet</servlet-name>
    <url-pattern>/grupos</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AvisosServlet</servlet-name>
    <servlet-class>com.delta.servlet.AvisosServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AvisosServlet</servlet-name>
    <url-pattern>/avisos</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NotasServlet</servlet-name>
    <servlet-class>com.delta.servlet.NotasServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NotasServlet</servlet-name>
    <url-pattern>/notas</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AsistenciaServlet</servlet-name>
    <servlet-class>com.delta.servlet.AsistenciaServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AsistenciaServlet</servlet-name>
    <url-pattern>/asistencia</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminServlet</servlet-name>
    <servlet-class>com.delta.servlet.AdminServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/admin</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MatriculaServlet</servlet-name>
    <servlet-class>com.delta.servlet.MatriculaServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MatriculaServlet</servlet-name>
    <url-pattern>/matricula</url-pattern>
  </servlet-mapping>

  <!-- Página de bienvenida -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Sesión 30 minutos -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

</web-app>
