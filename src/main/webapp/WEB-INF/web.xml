<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
           http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Sistema Delta UTP</display-name>

  <!-- ===== Conexión BD (parámetros XAMPP) ===== -->
  <context-param>
    <param-name>db.url</param-name>
    <param-value>jdbc:mysql://localhost:3306/sistema_delta?useSSL=false&amp;serverTimezone=America/Panama&amp;characterEncoding=UTF-8</param-value>
  </context-param>
  <context-param>
    <param-name>db.user</param-name>
    <param-value>root</param-value>
  </context-param>
  <context-param>
    <param-name>db.password</param-name>
    <param-value></param-value>
  </context-param>

  <!-- ===== Servlets ===== -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.delta.servlet.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.delta.servlet.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MensajesServlet</servlet-name>
    <servlet-class>com.delta.servlet.MensajesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MensajesServlet</servlet-name>
    <url-pattern>/mensajes</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GruposServlet</servlet-name>
    <servlet-class>com.delta.servlet.GruposServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GruposServlet</servlet-name>
    <url-pattern>/grupos</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NotasServlet</servlet-name>
    <servlet-class>com.delta.servlet.NotasServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NotasServlet</servlet-name>
    <url-pattern>/notas</url-pattern>
  </servlet-mapping>

  <!-- Página de bienvenida -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Sesión 30 minutos -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

</web-app>
